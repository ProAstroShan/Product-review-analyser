# Imports
import pandas as pd
import numpy as np
import math
import collections
from matplotlib import pyplot as plt

# Placing file into a usable table
try:
    with open("redmi6.csv.xls", "r", encoding="latin-1") as f:
        csv_data = pd.read_csv(f)
except FileNotFoundError as e:
    print(e)
else:
    useful_data_unformatted = csv_data["Useful"]
    rating_data: list[str] = [x for x in csv_data["Rating"]]
    useful_data: list[str] = [
        x if isinstance(x, str) and x != " " else "0 people found this helpful"
        for x in useful_data_unformatted
    ]

    # Formatting scores
    rating_score = np.array([float(x[0:3]) for x in rating_data])
    useful_score_unformatted = [str(x)[0] for x in useful_data]
    useful_score = np.array(
        [1 if x == "O" else int(x) for x in useful_score_unformatted]
    )

    # Formula to calculate effective score, unaffected by review bombs
    def score_calc(rating, useful):
        useful_multiplier = 2 * (1 - math.e ** (-0.09 * useful)) + 1
        score_total = rating * useful_multiplier
        return score_total, useful_multiplier

    # Calculating effective score
    sum_score_total = []
    sum_useful_multiplier = []
    for i in range(len(rating_score)):
        sum_score_total.append((score_calc(rating_score[i], useful_score[i]))[0])
        sum_useful_multiplier.append((score_calc(rating_score[i], useful_score[i]))[1])
    effective_score = sum(sum_score_total) / sum(sum_useful_multiplier)
    # Display effective score to 2 decimals
    message = (
        f"The effective score of this product is {effective_score:.2f} out of 5.00"
    )

    # Creating plots for the 3 graphs
    fig, ax = plt.subplots(1, 3, figsize=[12, 6])
    rating_bar = ax[0]
    useful_bar = ax[1]
    scatter_graph = ax[2]

    rating_count_unformatted = collections.Counter(rating_score)
    rating_count = []
    up_count = 1.0
    for i in range(len(rating_count_unformatted)):
        rating_count.append(rating_count_unformatted[up_count])
        up_count += 1.0

    # Adjusting details of the graph
    rating_bar.bar([1, 2, 3, 4, 5], rating_count)
    rating_bar.grid(linestyle="dashed")
    rating_bar.set_xticks([1, 2, 3, 4, 5])
    rating_bar.set_title("Rating Distribution", fontsize=14)
    rating_bar.set_xlabel("Rating readings", fontsize=13)
    rating_bar.set_ylabel("Number of people", fontsize=13)

    # Counting the usefulness score as a key, and frequency as a value
    useful_count_unformatted = collections.Counter(useful_score)
    useful_count = []
    up_count_2 = 1
    for i in range(len(useful_count_unformatted)):
        useful_count.append(useful_count_unformatted[up_count_2])
        up_count_2 += 1

    useful_bar.bar([0, 1, 2, 3, 4, 5, 6, 7, 8], useful_count)
    useful_bar.grid(linestyle="dashed")
    useful_bar.set_xticks([0, 1, 2, 3, 4, 5, 6, 7, 8])
    useful_bar.set_title("x People found rating useful", fontsize=14)
    useful_bar.set_xlabel("Usefulness", fontsize=13)
    useful_bar.set_ylabel("Number of people", fontsize=13)

    scatter_graph.scatter(rating_score, useful_score, alpha=0.25, s=100)
    scatter_graph.set_title("Density of Ratings vs Usefulness", fontsize=14)
    scatter_graph.set_xlabel("Number of Ratings", fontsize=13)
    scatter_graph.set_ylabel("Number of usefulness", fontsize=13)

    fig.suptitle("Product Review Summary", fontsize=21, ha="center")
    fig.text(0.5, -0.05, message, ha="center", va="bottom", fontsize=16)
    plt.tight_layout(rect=(0.05, 0, 0.95, 0.95))

    # Creating image summary
    plt.savefig(fname="Product_Review_Summary.png", dpi=100, bbox_inches="tight")
    plt.show()
